PORT=3000
GITHUB_WEBHOOK_SECRET=replace_me
ALLOWED_REPOS=owner1/repo1,owner2/repo2

# {"github_username":"0xWalletAddress"}
GITHUB_TO_WALLET_JSON={"alice":"0x1111111111111111111111111111111111111111"}

# set true for local webhook simulation without chain tx
MOCK_REWARD=false

RPC_URL=https://your-rpc-url
BOT_PRIVATE_KEY=0xyour_private_key
DISTRIBUTOR_CONTRACT=0xDistributorContractAddress

# USDC has 6 decimals.
OPEN_REWARD_USDC=0.1
MERGE_REWARD_USDC=0.1

# local JSON idempotency store
STORE_PATH=./data/store.json

# optional: enable admin dashboard at /admin (required for admin APIs)
ADMIN_TOKEN=replace_with_strong_token
